// ── Checklist ──────────────────────────────────────────────────
function Checklist({ checklist, onSave }) {
  const toggle = (id) => onSave(checklist.map(c => c.id === id ? { ...c, done: !c.done } : c));

  const groups = [...new Set(checklist.map(c => c.group))];

  return (
    <div>
      <h2 style={{ margin: "0 0 6px", fontSize: 17, fontWeight: 800, color: COLORS.plum, fontFamily: "Georgia, serif" }}>Next Steps Checklist</h2>
      <p style={{ color: COLORS.fog, fontSize: 13, marginTop: 0, marginBottom: 16 }}>Tap to check off items as you complete them.</p>

      {groups.map(g => (
        <div key={g}>
          <div style={{ fontSize: 11, fontWeight: 800, color: COLORS.dustyRose, textTransform: "uppercase", letterSpacing: "0.1em", margin: "18px 0 8px" }}>{g}</div>
          {checklist.filter(c => c.group === g).map(item => (
            <div key={item.id} onClick={() => toggle(item.id)} style={{
              display: "flex", alignItems: "flex-start", gap: 12, padding: "12px 16px",
              background: item.done ? COLORS.mist : COLORS.white, borderRadius: 10, marginBottom: 6,
              cursor: "pointer", border: `1.5px solid ${item.done ? COLORS.mist : COLORS.blush}`,
              opacity: item.done ? 0.7 : 1, transition: "all .15s",
            }}>
              <div style={{
                width: 20, height: 20, borderRadius: 6, border: `2px solid ${item.done ? COLORS.sage : COLORS.blush}`,
                background: item.done ? COLORS.sage : "transparent", display: "flex", alignItems: "center", justifyContent: "center",
                flexShrink: 0, marginTop: 1,
              }}>
                {item.done && <span style={{ color: COLORS.white, fontSize: 12, fontWeight: 800 }}>✓</span>}
              </div>
              <div>
                <div style={{ fontSize: 14, fontWeight: item.done ? 400 : 700, color: item.done ? COLORS.fog : COLORS.ink, textDecoration: item.done ? "line-through" : "none" }}>{item.label}</div>
                {item.note && <div style={{ fontSize: 12, color: COLORS.fog, marginTop: 2 }}>{item.note}</div>}
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  );
}

